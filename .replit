modules = ["ruby-3.2", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "ruby /home/runner/workspace/.local/share/gem/ruby/3.2.0/gems/bundler-2.4.10/exe/bundle exec jekyll serve --host 0.0.0.0 --port 5000 --livereload --force_polling"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "static"
build = ["ruby", "/home/runner/workspace/.local/share/gem/ruby/3.2.0/gems/bundler-2.4.10/exe/bundle", "exec", "jekyll", "build"]
publicDir = "_site"
